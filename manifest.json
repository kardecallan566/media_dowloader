{
    "manifest_version": 3,
    "name": "Media Finder Pro 🎥",
    "description": "Detector de mídias premium 🔍. Baixe vídeos em alta qualidade de qualquer site.",
    "version": "1.1.1",
    "action": {
        "default_title": "Media Finder 🔍",
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "webRequest",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}